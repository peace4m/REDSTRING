{
  "expo": {
    "name": "RedString",
    "slug": "redstring",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "backgroundColor": "#0A0A0C",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.redstring.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "RedString uses your microphone for War Room voice chat with other investigators.",
        "NSCameraUsageDescription": "RedString may use your camera for AR evidence scanning features.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.redstring.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#0A0A0C"
      },
      "permissions": [
        "RECORD_AUDIO",
        "NOTIFICATIONS",
        "VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "backgroundColor": "#0A0A0C",
          "imageWidth": 200
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/android-icon-foreground.png",
          "color": "#F5C842"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "2c81ea7b-3b5a-4ca8-a6fa-3fa1fdc6dbeb"
      }
    }
  }
}
